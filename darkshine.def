Bootstrap: docker
From: quay.io/almalinux/almalinux:9

%post
    # ── System packages ─────────────────────────────────────────────
    dnf -y install dnf-plugins-core
    dnf -y install epel-release
    dnf config-manager --set-enabled crb
    dnf -y --setopt=tsflags=nodocs install \
        cmake gcc-c++ gcc make git wget tar gzip which \
        mesa-libGL-devel mesa-libGLU-devel \
        libX11-devel libXpm-devel libXft-devel libXext-devel libXt-devel libXmu-devel \
        libGLEW glew-devel ftgl-devel \
        gsl-devel yaml-cpp-devel xerces-c-devel nlohmann-json-devel eigen3-devel \
        hdf5-devel boost-devel \
        protobuf-devel protobuf-compiler \
        openssl-devel expat-devel zlib-devel pcre2-devel xxhash-devel libzstd-devel lz4-devel libAfterImage-devel gl2ps-devel python3-devel python3-numpy libcurl-devel libuuid-devel && \
    dnf clean all

    INSTALL_PREFIX=/opt/darkshine
    export PATH=${INSTALL_PREFIX}/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:${LD_LIBRARY_PATH}

    mkdir -p /tmp/build
    cd /tmp/build

    # ── Download helper (codeload for GFW) ─────────────────────────
    cat > /usr/local/bin/ghdl << 'EOFDL'
#!/bin/bash
set -e
URL="https://codeload.github.com/$1/legacy.tar.gz/$2"
echo "Downloading ${URL} ..."
curl -sL --connect-timeout 30 --max-time 900 -o "$3" "${URL}"
echo "OK ($(ls -lh $3 | awk '{print $5}'))"
EOFDL
    chmod +x /usr/local/bin/ghdl

    # ── Geant4 10.6.3 ───────────────────────────────────────────
    ghdl Geant4/geant4 v10.6.3 geant4.tar.gz
    tar xzf geant4.tar.gz
    cd Geant4-geant4-*
    rm -rf _build && mkdir _build && cd _build
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DCMAKE_CXX_FLAGS="-Wno-error=maybe-uninitialized -Wno-error=stringop-overflow" \
        -DGEANT4_INSTALL_DATA=ON \
        -DGEANT4_USE_OPENGL_X11=ON \
        -DGEANT4_USE_RAYTRACER_X11=ON \
        -DGEANT4_BUILD_MULTITHREADED=ON
    make -j4
    make install
    cd /tmp/build && rm -rf Geant4-* geant4.tar.gz

    # ── ROOT 6.30.06 ───────────────────────────────────────────
    ghdl root-project/root v6-30-06 root.tar.gz
    tar xzf root.tar.gz
    cd root-*
    ROOT_SRC=$(pwd)
    rm -rf _build && mkdir _build && cd _build
    cmake ${ROOT_SRC} \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DCMAKE_CXX_STANDARD=17 \
        -Droot7=OFF -Dtmva=ON -Deve=ON -Dgui=ON -Dgdml=ON -Drgl=ON -Deg=ON \
        -Dx11=ON -Dopengl=ON -Dmysql=OFF -Dpgsql=OFF \
        -Dsql=OFF -Dsqlite=OFF \
        -Dfftw3=OFF -Dgfal=OFF -Ddavix=OFF -Dhttp=OFF -Dcfitsio=OFF \
        -Dnet=OFF \
        -Dfail-on-missing=OFF
    make -j4
    make install
    cd /tmp/build && rm -rf root-* root.tar.gz

    # ── ACTS (ykrsama/xuliang-v30) ──────────────────────────────
    ghdl ykrsama/acts xuliang-v30 acts.tar.gz
    tar xzf acts.tar.gz
    cd ykrsama-acts-*
    rm -rf _build && mkdir _build && cd _build
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DCMAKE_CXX_STANDARD=17 \
        -DACTS_BUILD_PLUGIN_JSON=ON \
        -DACTS_BUILD_EXAMPLES=OFF \
        -DACTS_BUILD_FATRAS=OFF \
        -DACTS_BUILD_ALIGNMENT=OFF \
        -DACTS_BUILD_UNITTESTS=OFF
    make -j4
    make install
    cd /tmp/build && rm -rf ykrsama-acts-* acts.tar.gz

    # ── ONNX Runtime ───────────────────────────────────────────
    ghdl microsoft/onnxruntime v1.16.3 onnx.tar.gz
    tar xzf onnx.tar.gz
    cd onnxruntime-*
    ./build.sh --config Release --build_shared_lib --parallel 4 \
        --skip_tests --use_cuda=OFF
    cp -r include/onnxruntime ${INSTALL_PREFIX}/include/
    find build/Linux/Release -name 'libonnxruntime*.so*' \
        -exec cp -a {} ${INSTALL_PREFIX}/lib/ \;
    cd /tmp/build && rm -rf onnxruntime-* onnx.tar.gz

    # ── Setup script ───────────────────────────────────────────
    cat > ${INSTALL_PREFIX}/setup.sh << 'EOF'
#!/bin/bash
export DSS_DIR=/opt/darkshine
export PATH=${DSS_DIR}/bin:${PATH}
export LD_LIBRARY_PATH=${DSS_DIR}/lib:${DSS_DIR}/lib64:${LD_LIBRARY_PATH}
source ${DSS_DIR}/bin/geant4.sh
source ${DSS_DIR}/bin/thisroot.sh
echo "DarkSHINE environment loaded"
EOF
    chmod +x ${INSTALL_PREFIX}/setup.sh

    # ── Verify ─────────────────────────────────────────────────
    echo "=== Versions ==="
    gcc --version | head -1
    cmake --version | head -1
    ${INSTALL_PREFIX}/bin/geant4-config --version 2>/dev/null || echo "Geant4: installed"
    ${INSTALL_PREFIX}/bin/root --version 2>/dev/null | head -1 || echo "ROOT: installed"
    echo "=== Done ==="

    rm -rf /tmp/build

    # ── Optimise size ────────────────────────────────────────────
    find ${INSTALL_PREFIX}/lib -name '*.a' -delete 2>/dev/null
    find ${INSTALL_PREFIX}/lib64 -name '*.a' -delete 2>/dev/null
    strip --strip-unneeded ${INSTALL_PREFIX}/lib/*.so ${INSTALL_PREFIX}/lib64/*.so 2>/dev/null
    strip ${INSTALL_PREFIX}/bin/* 2>/dev/null
    dnf clean all
    rm -rf /var/cache/dnf /var/log/dnf*

%environment
    export INSTALL_PREFIX=/opt/darkshine
    export PATH=/opt/darkshine/bin:${PATH}
    export LD_LIBRARY_PATH=/opt/darkshine/lib:/opt/darkshine/lib64:${LD_LIBRARY_PATH}

%runscript
    source /opt/darkshine/setup.sh
    exec /bin/bash "$@"

%startscript
    source /opt/darkshine/setup.sh
    exec /bin/bash "$@"
