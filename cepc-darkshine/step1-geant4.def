Bootstrap: localimage
From: ../common/common.sif

%files
    geant4-v10.6.3.tar.gz /opt/geant4.tar.gz

%post
    INSTALL_PREFIX=/opt/common
    set -e
    dnf -y install xerces-c-devel
    mkdir -p /tmp/build
    cd /tmp/build

    tar xzf /opt/geant4.tar.gz
    cd Geant4-geant4-*
    rm -rf _build && mkdir _build && cd _build
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DCMAKE_CXX_FLAGS="-Wno-error=maybe-uninitialized -Wno-error=stringop-overflow" \
        -DGEANT4_INSTALL_DATA=ON \
        -DGEANT4_USE_GDML=ON \
        -DGEANT4_USE_OPENGL_X11=ON \
        -DGEANT4_BUILD_MULTITHREADED=ON
    make -j4 && make install
    rm -rf ${INSTALL_PREFIX}/share/Geant4-*/data/RealSurface* \
           ${INSTALL_PREFIX}/share/Geant4-*/data/G4NDL*
    rm -rf ${INSTALL_PREFIX}/share/Geant4-*/examples
    echo "source ${INSTALL_PREFIX}/bin/geant4.sh" >> /etc/profile.d/common.sh
    cd /tmp/build && rm -rf Geant4-*
    rm -rf /tmp/build

%environment
    export INSTALL_PREFIX=/opt/common
    export PATH=${INSTALL_PREFIX}/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:${LD_LIBRARY_PATH}
