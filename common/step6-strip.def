Bootstrap: localimage
From: ../common/common.sif

%post
    set -e

    # Strip shared libraries
    find /opt/common/lib -name '*.so' -exec strip --strip-unneeded {} \; 2>/dev/null || true
    find /opt/common/lib64 -name '*.so' -exec strip --strip-unneeded {} \; 2>/dev/null || true

    # Strip binaries
    find /opt/common/bin -type f -executable -exec strip {} \; 2>/dev/null || true

    # Remove static libraries
    find /opt -name '*.a' -delete 2>/dev/null || true

    # Clean caches
    dnf clean all 2>/dev/null || true
    rm -rf /var/cache/dnf /var/log/dnf*
    rm -rf /root/.cache/pip

%environment
    export INSTALL_PREFIX=/opt/common
    export PATH=${INSTALL_PREFIX}/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:${LD_LIBRARY_PATH}
