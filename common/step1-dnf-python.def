Bootstrap: docker
From: quay.io/almalinux/almalinux:9

%post
    dnf -y install dnf-plugins-core epel-release
    dnf config-manager --set-enabled crb
    dnf -y --setopt=tsflags=nodocs install \
        cmake gcc-c++ gcc make git wget tar gzip which \
        python3.12 python3.12-devel python3.12-pip \
        mesa-libGL-devel mesa-libGLU-devel \
        libX11-devel libXpm-devel libXft-devel libXext-devel libXt-devel libXmu-devel \
        openssl-devel expat-devel zlib-devel pcre2-devel \
        xxhash-devel libzstd-devel lz4-devel libAfterImage-devel gl2ps-devel \
        libcurl-devel libuuid-devel tbb-devel

    # Python 3.12 packages via pip (exact versions)
    python3.12 -m pip install --no-cache-dir \
        numpy==2.4.6 \
        matplotlib==3.10.9 \
        uproot==5.7.4 \
        awkward==2.9.0

    dnf clean all
    rm -rf /var/cache/dnf /var/log/dnf*

%environment
    export PATH=/usr/bin:${PATH}
