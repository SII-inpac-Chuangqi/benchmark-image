Bootstrap: localimage
From: common-step1.sif

%post
    INSTALL_PREFIX=/opt/common
    set -e
    mkdir -p /tmp/build ${INSTALL_PREFIX}
    cd /tmp/build

    curl -sL -o hepmc3.tar.gz "https://gitlab.cern.ch/hepmc/HepMC3/-/archive/3.3.1/HepMC3-3.3.1.tar.gz"
    tar xzf hepmc3.tar.gz
    cd HepMC3-*

    mkdir _build && cd _build
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DCMAKE_CXX_STANDARD=17 \
        -DHEPMC3_ENABLE_ROOTIO=OFF \
        -DHEPMC3_ENABLE_PYTHON=ON \
        -DHEPMC3_PYTHON_VERSION=3.12 \
        -DHEPMC3_BUILD_EXAMPLES=OFF
    make -j4 && make install

    cd /tmp/build && rm -rf HepMC3-* hepmc3.tar.gz
    rm -rf /tmp/build

%environment
    export INSTALL_PREFIX=/opt/common
    export PATH=${INSTALL_PREFIX}/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:${LD_LIBRARY_PATH}
