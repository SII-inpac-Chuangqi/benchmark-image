Bootstrap: localimage
From: lhc-step1.sif

%files
    MG5_aMC_v3.5.13.tar.gz /opt/mg5.tar.gz

%post
    INSTALL_PREFIX=/opt/common
    MG5_DIR=/opt/mg5
    set -e

    ls -lh /opt/mg5.tar.gz
    cd /opt && tar xzf mg5.tar.gz && rm mg5.tar.gz
    mv MG5_aMC_v3_5_13 ${MG5_DIR}

    # Fix MG5 3.5.13 bug: import logging before it is used (line 28)
    sed -i '27i import logging' ${MG5_DIR}/bin/mg5_aMC

    # Install rsync (needed by Pythia8 install)
    dnf -y install rsync

    cd ${MG5_DIR}
    echo "install pythia8" | ./bin/mg5_aMC 2>&1 | tail -5

    echo "export PATH=${MG5_DIR}/bin:\${PATH}" >> /etc/profile.d/common.sh

%environment
    export INSTALL_PREFIX=/opt/common
    export PATH=/opt/mg5/bin:${INSTALL_PREFIX}/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:${LD_LIBRARY_PATH}
