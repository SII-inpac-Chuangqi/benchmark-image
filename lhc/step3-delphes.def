Bootstrap: localimage
From: lhc-step2.sif

%post
    INSTALL_PREFIX=/opt/common
    set -e
    dnf -y install tcl
    mkdir -p /tmp/build
    cd /tmp/build

    cat > /usr/local/bin/ghdl << 'EOFDL'
#!/bin/bash
set -e
URL="https://codeload.github.com/$1/legacy.tar.gz/$2"
curl -sL --connect-timeout 30 --max-time 900 -o "$3" "${URL}"
EOFDL
    chmod +x /usr/local/bin/ghdl

    ghdl delphes/delphes 3.5.0 delphes.tar.gz
    tar xzf delphes.tar.gz
    cd delphes-*

    source /opt/common/bin/thisroot.sh

    # Build with CMake (matching CEPC Delphes build pattern)
    # CMake's ROOT_GENERATE_DICTIONARY produces lib-prefixed PCMs
    # that ROOT finds alongside the library — no manual PCM copy needed
    mkdir _build && cd _build
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=${INSTALL_PREFIX} \
        -DPYTHIA8=/opt/mg5/HEPTools/pythia8
    make -j4
    make install

    cd /tmp/build && rm -rf delphes-* delphes.tar.gz
    rm -rf /tmp/build

%environment
    export INSTALL_PREFIX=/opt/common
    export PATH=${INSTALL_PREFIX}/bin:/opt/mg5/bin:${PATH}
    export LD_LIBRARY_PATH=${INSTALL_PREFIX}/lib:${INSTALL_PREFIX}/lib64:/opt/mg5/HEPTools/pythia8/lib:${LD_LIBRARY_PATH}
